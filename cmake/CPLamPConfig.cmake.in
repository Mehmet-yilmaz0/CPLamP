@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(Eigen3 CONFIG REQUIRED)
find_dependency(fmt CONFIG REQUIRED)
find_dependency(spdlog CONFIG REQUIRED)

include("${CMAKE_CURRENT_LIST_DIR}/CPLamPTargets.cmake")

# Static library pulls symbols from these; they are not listed in the export file
# to avoid requiring FetchContent targets at install time.
if(TARGET CPLamP::ai)
    target_link_libraries(CPLamP::ai INTERFACE Eigen3::Eigen fmt::fmt spdlog::spdlog)
endif()

check_required_components(CPLamP)
